APP_NAME=voice-note-collector
ENVIRONMENT=local

SECRET_KEY= # Required in all environments — no default

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USER=
TELEGRAM_WEBHOOK_SECRET= # Required in prod — must match the secret set in Telegram setWebhook call
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_NOTIFY_ON_TRANSCRIPTION=true  # Set to false to disable post-transcription Telegram confirmations

SUPABASE_URL=
SUPABASE_KEY=

API_KEY= # Required in prod — sent as X-API-Key header by REST clients

GROQ_API_KEY=
